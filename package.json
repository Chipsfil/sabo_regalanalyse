{
  "name": "sabo-regalanalyse-app",
  "productName": "Sabo Regalanalyse",
  "version": "1.2.3",
  "main": "main.js",
  "homepage": "https://github.com/Chipsfil/sabo_regalanalyse",
  "scripts": {
    "start": "electron .",
    "build-icons": "electron-icon-builder --input=assets/icon.png --output=build --flatten",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "publish": "electron-builder --publish always"
  },
  "dependencies": {
    "electron-store": "^10.1.0",
    "electron-updater": "^6.8.3",
    "exceljs": "^4.4.0",
    "fs-extra": "^11.1.1",
    "sweetalert2": "^11.22.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1",
    "electron-icon-builder": "^2.0.1"
  },
  "build": {
    "appId": "com.sabo.regalanalyse",
    "productName": "Sabo Regalanalyse",
    "copyright": "Copyright © 2026 Oleificio Sabo",
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "Chipsfil",
      "repo": "sabo_regalanalyse"
    }
  }
}
